# Copiar a secrets.toml en esta misma carpeta. No subir secrets.toml a Git.

[connections.supabase]
SUPABASE_URL = "https://TU-PROYECTO.supabase.co"
# Recomendado en Streamlit Cloud: service_role (Settings → API).
# Si usás anon, en Supabase tenés que tener las políticas del schema.sql (o patch_001).
SUPABASE_KEY = "pega_aqui_service_role_o_anon"

# Opcional: firma de la cookie de sesión (si no, se deriva de SUPABASE_KEY).
# [auth]
# SESSION_SIGNING_KEY = "cadena_larga_aleatoria"
