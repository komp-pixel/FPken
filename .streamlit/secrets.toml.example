# Copiar a secrets.toml en esta misma carpeta. No subir secrets.toml a Git.
#
# Supabase → Project Settings → API:
#   - SUPABASE_URL = Project URL
#   - SUPABASE_KEY = JWT **service_role** (texto largo que empieza con eyJ...), en "Legacy API keys".
#   No pegues sb_secret_... aquí: supabase-py 2.8 solo acepta JWT.

[connections.supabase]
SUPABASE_URL = "https://TU-PROYECTO.supabase.co"
SUPABASE_KEY = "eyJ...pega_aqui_el_JWT_service_role_legacy..."

# Opcional: firma de la cookie de sesión (si no, se deriva de SUPABASE_KEY).
# [auth]
# SESSION_SIGNING_KEY = "cadena_larga_aleatoria"
